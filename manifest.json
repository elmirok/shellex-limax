{
  "id": "system.limax.local",
  "name": "Limax",
  "version": "1.0.2",
  "author": "Shellex",
  "description": "The local-first Shellex package manager for vault apps, repo registries and updates.",
  "repository": "https://github.com/elmirok/shellex-limax",
  "type": "system-app",
  "entry": "README.md",
  "runtime": "host",
  "permissions": [
    "apps:list",
    "apps:install",
    "apps:remove"
  ],
  "window": {
    "width": 820,
    "height": 620,
    "resizable": true
  }
}
